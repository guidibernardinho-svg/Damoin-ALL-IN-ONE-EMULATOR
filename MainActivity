package com.allemu.app;

import android.content.Intent;
import android.net.Uri;
import android.os.Bundle;
import android.widget.Button;
import androidx.appcompat.app.AppCompatActivity;

public class MainActivity extends AppCompatActivity {

    Button btnRetro, btnPSP, btnGC;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        btnRetro = findViewById(R.id.retro);
        btnPSP = findViewById(R.id.psp);
        btnGC = findViewById(R.id.gc);

        btnRetro.setOnClickListener(v -> openApp("com.retroarch"));
        btnPSP.setOnClickListener(v -> openApp("org.ppsspp.ppsspp"));
        btnGC.setOnClickListener(v -> openApp("org.dolphinemu.dolphinemu"));
    }

    void openApp(String packageName) {
        Intent intent = getPackageManager().getLaunchIntentForPackage(packageName);
        if (intent != null) {
            startActivity(intent);
        }
    }
}
